APP_NAME="Plateforme Permis de Construire"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=plateforme_permis_construire
DB_USERNAME=root
DB_PASSWORD=

# Session & Cache
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# AI Microservice (FastAPI)
AI_SERVICE_URL=http://localhost:8001

# File Storage
FILESYSTEM_DISK=public

# Mail (optional - for email notifications)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@permisconstruct.ma"
MAIL_FROM_NAME="${APP_NAME}"
